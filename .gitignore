# Ignore all files and directories by default
*

# Allow the .gitignore file itself
!.gitignore

# Allow the specific directories to be tracked
!config/
!config/**
!controllers/
!controllers/**
!middleware/
!middleware/**
!models/
!models/**
!routes/
!routes/**
!uploads/**
!server.js
!app.js
!uploads/
!uploads/**

# Allow frontend directory
!frontend/
!frontend/**

# Ignore frontend dependencies and build outputs
frontend/node_modules/
frontend/dist/
frontend/.vite/
